generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../database.sqlite"
}

model User {
  id       String @id @default(uuid())
  imageUrl String
  username String
  email    String
  password String
  role     String @default("user")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  waitingListEntries WaitingList[]
}

model Cource {
  id          String @id @default(uuid())
  imageUrl    String
  name        String
  description String
  studyTime   String
  price       Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams               Team[]
  waitingListEntries  WaitingList[]
}

model WaitingList {
  id       String @id @default(uuid())
  userId   String
  courceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cource Cource @relation(fields: [courceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courceId])
  @@unique([userId, courceId])
}

model Team {
  id               String @id @default(uuid())
  courceId         String
  name             String
  assignedUsersIds Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cource Cource @relation(fields: [courceId], references: [id], onDelete: Cascade)

  @@index([courceId])
}
